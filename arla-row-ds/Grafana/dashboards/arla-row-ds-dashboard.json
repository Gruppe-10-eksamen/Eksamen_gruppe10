{
  "title": "Arla RoW DS — Order Processing Observability",
  "uid": "arla-row-ds-dashboard",
  "schemaVersion": 36,
  "version": 2,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests per sekund (alle endpoints)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP request latency p95 (sekunder)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_highr_seconds_bucket[1m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "POST /orders — requests total",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=\"/orders\", method=\"POST\"})",
          "legendFormat": "Ordrer modtaget"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 4,
      "title": "POST /orders — 2xx (success)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=\"/orders\", method=\"POST\", status_code=~\"2..\"})",
          "legendFormat": "Valideret / oprettet"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "POST /orders — 4xx (afvist)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=\"/orders\", method=\"POST\", status_code=~\"4..\"})",
          "legendFormat": "Afvist"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 5 },
            { "color": "red", "value": 20 }
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "GET /contracts — requests total",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(http_requests_total{handler=~\"/contracts.*\", method=\"GET\"})",
          "legendFormat": "Contract lookups"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none" }
    },
    {
      "id": 7,
      "title": "Ordreflow over tid — POST /orders (2xx vs 4xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{handler=\"/orders\", method=\"POST\", status_code=~\"2..\"}[1m])",
          "legendFormat": "Oprettet (2xx)/sek"
        },
        {
          "expr": "rate(http_requests_total{handler=\"/orders\", method=\"POST\", status_code=~\"4..\"}[1m])",
          "legendFormat": "Afvist (4xx)/sek"
        },
        {
          "expr": "rate(http_requests_total{handler=\"/orders\", method=\"POST\"}[1m])",
          "legendFormat": "Total/sek"
        }
      ]
    },
    {
      "id": 8,
      "title": "Requests fordelt på endpoints (pie)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (handler) (http_requests_total)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "HTTP fejlrate (4xx + 5xx) per endpoint",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total{status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status_code}} {{handler}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "PostgreSQL — aktive forbindelser",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "Aktive forbindelser"
        }
      ]
    },
    {
      "id": 11,
      "title": "PostgreSQL — inserts per sekund",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"arla_row\"}[1m])",
          "legendFormat": "Inserts/sek"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"arla_row\"}[1m])",
          "legendFormat": "Updates/sek"
        }
      ]
    }
  ]
}